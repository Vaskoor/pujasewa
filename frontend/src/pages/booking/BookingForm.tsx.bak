import { useEffect, useState } from 'react';
import { useParams, useNavigate } from 'react-router-dom';
import api from '../../services/api';
import { LoadingSpinner } from '../../components/LoadingSpinner';

export function BookingForm() {
  const { panditId } = useParams();
  const navigate     = useNavigate();
  const [pandit,     setPandit]     = useState<any>(null);
  const [eventTypes, setEventTypes] = useState<any[]>([]);
  const [packages,   setPackages]   = useState<any[]>([]);
  const [formData,   setFormData]   = useState({ eventTypeId: '', eventDate: '', eventTime: '', location: '', packageId: '' });
  const [loading,    setLoading]    = useState(true);
  const [submitting, setSubmitting] = useState(false);
  const [error,      setError]      = useState('');

  useEffect(() => {
    Promise.all([
      api.get(`/pandits/${panditId}`),
      api.get('/events'),
      api.get('/packages'),
    ]).then(([panditRes, eventsRes, packagesRes]) => {
      setPandit(panditRes.data);
      setEventTypes(Array.isArray(eventsRes.data) ? eventsRes.data : []);
      setPackages(Array.isArray(packagesRes.data) ? packagesRes.data : []);
    }).catch(() => setError('Failed to load booking data.'))
      .finally(() => setLoading(false));
  }, [panditId]);

  const set = (field: string) => (e: React.ChangeEvent<HTMLInputElement | HTMLSelectElement>) =>
    setFormData(f => ({ ...f, [field]: e.target.value }));

  const handleSubmit = async (e: React.FormEvent) => {
    e.preventDefault();
    setSubmitting(true);
    setError('');
    try {
      const res = await api.post('/bookings', { ...formData, panditId });
      navigate(`/payment/${res.data.id}`);
    } catch (err: any) {
      setError(err.response?.data?.message || 'Booking failed. Please try again.');
    } finally {
      setSubmitting(false);
    }
  };

  if (loading) return <LoadingSpinner />;

  const panditName = pandit?.user?.profile?.fullName || 'this Pandit';
  const selectedPkg = packages.find((p: any) => p.id === formData.packageId);

  return (
    <div className="max-w-lg mx-auto px-4 py-12">
      <h1 className="text-2xl font-bold text-gray-800 mb-1">Book {panditName}</h1>
      <p className="text-gray-500 mb-8">Fill in the details below to confirm your ceremony.</p>

      <div className="card p-8">
        {error && (
          <div className="bg-red-50 border border-red-200 text-red-700 rounded-lg px-4 py-3 mb-5 text-sm">
            ⚠️ {error}
          </div>
        )}

        <form onSubmit={handleSubmit} className="space-y-5">
          <div className="flex items-center gap-2 my-3">
            <input type="checkbox" id="recurring" checked={formData.isRecurring} onChange={e => setFormData({...formData, isRecurring: e.target.checked})} />
            <label htmlFor="recurring" className="text-sm text-gray-700">Repeat weekly</label>
          </div>
          {formData.isRecurring && (
            <div>
              <label className="block text-sm font-medium text-gray-700 mb-1">Repeat every</label>
              <select value={formData.recurrenceInterval || 1} onChange={e => setFormData({...formData, recurrenceInterval: parseInt(e.target.value)})} className="input-field">
                <option value="1">1 week</option>
                <option value="2">2 weeks</option>
                <option value="4">4 weeks</option>
              </select>
            </div>
          )}
          <div>
            <label className="block text-sm font-medium text-gray-700 mb-1">Duration (minutes)</label>
            <input type="number" value={formData.duration || 60} onChange={e => setFormData({...formData, duration: parseInt(e.target.value)})} className="input-field" min="15" step="15" />
          </div>          <div>
            <label className="block text-sm font-medium text-gray-700 mb-1">Event Type *</label>
            <select required value={formData.eventTypeId} onChange={set('eventTypeId')} className="input-field">
              <option value="">Select event type…</option>
              {eventTypes.map((et: any) => <option key={et.id} value={et.id}>{et.name}</option>)}
            </select>
          </div>

          <div>
            <label className="block text-sm font-medium text-gray-700 mb-1">Package (optional)</label>
            <select value={formData.packageId} onChange={set('packageId')} className="input-field">
              <option value="">No package — standard booking</option>
              {packages.map((pkg: any) => (
                <option key={pkg.id} value={pkg.id}>{pkg.name} — NPR {pkg.price.toLocaleString()}</option>
              ))}
            </select>
            {selectedPkg && (
              <p className="text-xs text-gray-500 mt-1">
                Includes: {selectedPkg.includesItems?.join(', ') || 'standard items'}
              </p>
            )}
          </div>

          <div className="grid grid-cols-2 gap-4">
            <div>
              <label className="block text-sm font-medium text-gray-700 mb-1">Date *</label>
              <input
                type="date"
                required
                min={new Date().toISOString().split('T')[0]}
                value={formData.eventDate}
                onChange={set('eventDate')}
                className="input-field"
              />
            </div>
            <div>
              <label className="block text-sm font-medium text-gray-700 mb-1">Time *</label>
              <input type="time" required value={formData.eventTime} onChange={set('eventTime')} className="input-field" />
            </div>
          </div>

          <div>
            <label className="block text-sm font-medium text-gray-700 mb-1">Location / Address *</label>
            <input
              type="text"
              required
              placeholder="e.g. Pashupatinath, Kathmandu"
              value={formData.location}
              onChange={set('location')}
              className="input-field"
            />
          </div>

          <button type="submit" disabled={submitting} className="btn-primary w-full py-3">
            {submitting ? 'Submitting…' : 'Proceed to Payment →'}
          </button>
        </form>
      </div>
    </div>
  );
}
