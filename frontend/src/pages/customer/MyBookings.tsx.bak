import { useState } from 'react';
import { useQuery, useMutation, useQueryClient } from '@tanstack/react-query';
import { Link } from 'react-router-dom';
import api from '../../services/api';
import { LoadingSpinner } from '../../components/LoadingSpinner';
import { ReviewModal } from '../../components/ReviewModal';
import { BookingDetailModal } from '../../components/BookingDetailModal';
import { CancelModal } from '../../components/CancelModal';
import { RescheduleModal } from "../components/RescheduleModal";

// ── status helpers ────────────────────────────────────────────
const STATUS_LABEL: Record<string, string> = {
  PENDING:     'Pending',
  ACCEPTED:    'Accepted',
  CONFIRMED:   'Confirmed',
  IN_PROGRESS: 'In Progress',
  COMPLETED:   'Completed',
  CANCELLED:   'Cancelled',
  REFUNDED:    'Refunded',
};
const STATUS_CLASS: Record<string, string> = {
  PENDING:     'bg-yellow-100 text-yellow-800 border border-yellow-200',
  ACCEPTED:    'bg-blue-100  text-blue-800  border border-blue-200',
  CONFIRMED:   'bg-green-100 text-green-800 border border-green-200',
  IN_PROGRESS: 'bg-purple-100 text-purple-800 border border-purple-200',
  COMPLETED:   'bg-gray-100  text-gray-700  border border-gray-200',
  CANCELLED:   'bg-red-100   text-red-800   border border-red-200',
  REFUNDED:    'bg-orange-100 text-orange-800 border border-orange-200',
};
const PAYMENT_CLASS: Record<string, string> = {
  UNPAID:       'bg-red-50   text-red-700',
  ADVANCE_PAID: 'bg-yellow-50 text-yellow-700',
  FULL_PAID:    'bg-green-50 text-green-700',
  REFUNDED:     'bg-gray-50  text-gray-600',
};

const TABS = ['All', 'Upcoming', 'Completed', 'Cancelled'] as const;
type Tab = typeof TABS[number];

// ── component ─────────────────────────────────────────────────
export function MyBookings() {
  const queryClient = useQueryClient();
  const [activeTab,    setActiveTab]    = useState<Tab>('All');
  const [reviewBooking, setReviewBooking] = useState<any | null>(null);
  const [detailBooking, setDetailBooking] = useState<any | null>(null);
  const [cancelBooking, setCancelBooking] = useState<any | null>(null);
  const [rescheduleBooking, setRescheduleBooking] = useState<any>(null);

  const { data: bookings = [], isLoading } = useQuery<any[]>({
    queryKey: ['my-bookings'],
    queryFn:  () => api.get('/users/bookings').then(r => r.data),
  });

  const cancelMutation = useMutation({
    mutationFn: ({ id, reason }: { id: string; reason: string }) =>
      api.patch(`/bookings/${id}/status`, { status: 'CANCELLED', cancellationReason: reason }),
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ['my-bookings'] });
      setCancelBooking(null);
    },
  });

  // ── filter by tab ──
  const filtered = bookings.filter((b: any) => {
    if (activeTab === 'All')       return true;
    if (activeTab === 'Upcoming')  return ['PENDING','ACCEPTED','CONFIRMED','IN_PROGRESS'].includes(b.status);
    if (activeTab === 'Completed') return b.status === 'COMPLETED';
    if (activeTab === 'Cancelled') return ['CANCELLED','REFUNDED'].includes(b.status);
    return true;
  });

  // ── tab counts ──
  const counts: Record<Tab, number> = {
    All:       bookings.length,
    Upcoming:  bookings.filter((b:any) => ['PENDING','ACCEPTED','CONFIRMED','IN_PROGRESS'].includes(b.status)).length,
    Completed: bookings.filter((b:any) => b.status === 'COMPLETED').length,
    Cancelled: bookings.filter((b:any) => ['CANCELLED','REFUNDED'].includes(b.status)).length,
  };

  return (
    <div>
      {/* ── Header ── */}
      <div className="flex items-center justify-between mb-6">
        <div>
          <h1 className="text-2xl font-bold text-gray-800">My Bookings</h1>
          <p className="text-gray-500 text-sm mt-0.5">Track and manage all your ceremony bookings</p>
        </div>
        <Link to="/pandits" className="btn-primary text-sm py-2 px-5">
          + New Booking
        </Link>
      </div>

      {/* ── Tabs ── */}
      <div className="flex gap-1 bg-gray-100 p-1 rounded-lg mb-6 w-fit">
        {TABS.map(tab => (
          <button
            key={tab}
            onClick={() => setActiveTab(tab)}
            className={`px-4 py-1.5 rounded-md text-sm font-medium transition-all ${
              activeTab === tab
                ? 'bg-white text-gray-800 shadow-sm'
                : 'text-gray-500 hover:text-gray-700'
            }`}
          >
            {tab}
            <span className={`ml-1.5 text-xs rounded-full px-1.5 py-0.5 ${
              activeTab === tab ? 'bg-orange-100 text-orange-600' : 'bg-gray-200 text-gray-500'
            }`}>
              {counts[tab]}
            </span>
          </button>
        ))}
      </div>

      {/* ── Content ── */}
      {isLoading ? (
        <LoadingSpinner text="Loading your bookings…" />
      ) : filtered.length === 0 ? (
        <EmptyState tab={activeTab} />
      ) : (
        <div className="space-y-4">
          {filtered.map((booking: any) => (
            <BookingCard
              key={booking.id}
              booking={booking}
              onViewDetails={() => setDetailBooking(booking)}
              onReview={() => setReviewBooking(booking)}
              onCancel={() => setCancelBooking(booking)}
            />
          ))}
        </div>
      )}

      {/* ── Modals ── */}
      {detailBooking && (
        <BookingDetailModal
          booking={detailBooking}
          onClose={() => setDetailBooking(null)}
        />
      )}
      {reviewBooking && (
        <ReviewModal
          booking={reviewBooking}
          onClose={() => setReviewBooking(null)}
          onSuccess={() => {
            queryClient.invalidateQueries({ queryKey: ['my-bookings'] });
            setReviewBooking(null);
          }}
        />
      )}
      {cancelBooking && (
        <CancelModal
          booking={cancelBooking}
          onClose={() => setCancelBooking(null)}
          onConfirm={(reason) => cancelMutation.mutate({ id: cancelBooking.id, reason })}
          isLoading={cancelMutation.isPending}
        />
      )}
    </div>
  );
}

// ── BookingCard ───────────────────────────────────────────────
function BookingCard({ booking, onViewDetails, onReview, onCancel }: {
  booking: any;
  onViewDetails: () => void;
  onReview: () => void;
  onCancel: () => void;
}) {
  const panditName  = booking.pandit?.user?.profile?.fullName || 'Pandit';
  const eventName   = booking.eventType?.name || 'Ceremony';
  const eventDate   = new Date(booking.eventDate);
  const isUpcoming  = ['PENDING','ACCEPTED','CONFIRMED','IN_PROGRESS'].includes(booking.status);
  const canReview   = booking.status === 'COMPLETED' && !booking.review;
  const canCancel   = ['PENDING','ACCEPTED'].includes(booking.status);
  const isPaid      = ['ADVANCE_PAID','FULL_PAID'].includes(booking.paymentStatus);

  return (
    <div className="card p-0 overflow-hidden">
      {/* Top colour bar by status */}
      <div className={`h-1 w-full ${
        booking.status === 'COMPLETED' ? 'bg-gray-400' :
        booking.status === 'CANCELLED' ? 'bg-red-400' :
        booking.status === 'CONFIRMED' ? 'bg-green-400' :
        'bg-orange-400'
      }`} />

      <div className="p-5">
        <div className="flex flex-col sm:flex-row sm:items-start gap-4">

          {/* Pandit Avatar */}
          <div className="w-14 h-14 rounded-full bg-orange-100 flex items-center justify-center text-2xl flex-shrink-0 ring-2 ring-orange-100">
            {booking.pandit?.user?.profile?.photo
              ? <img src={booking.pandit.user.profile.photo} alt={panditName} className="w-full h-full rounded-full object-cover" />
              : '🧑‍⚕️'}
          </div>

          {/* Main info */}
          <div className="flex-1 min-w-0">
            <div className="flex flex-wrap items-center gap-2 mb-1">
              <h3 className="font-bold text-gray-800 text-lg">{eventName}</h3>
              <span className={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${STATUS_CLASS[booking.status]}`}>
                {STATUS_LABEL[booking.status]}
              </span>
            </div>

            <p className="text-gray-600 text-sm mb-3">
              with <span className="font-medium text-gray-800">{panditName}</span>
            </p>

            {/* Details grid */}
            <div className="grid grid-cols-2 sm:grid-cols-4 gap-3 text-sm">
              <div>
                <p className="text-gray-400 text-xs uppercase tracking-wide mb-0.5">Date</p>
                <p className="font-medium text-gray-700">
                  {eventDate.toLocaleDateString('en-NP', { day: 'numeric', month: 'short', year: 'numeric' })}
                </p>
              </div>
              <div>
                <p className="text-gray-400 text-xs uppercase tracking-wide mb-0.5">Time</p>
                <p className="font-medium text-gray-700">{booking.eventTime}</p>
              </div>
              <div>
                <p className="text-gray-400 text-xs uppercase tracking-wide mb-0.5">Location</p>
                <p className="font-medium text-gray-700 truncate">{booking.location}</p>
              </div>
              <div>
                <p className="text-gray-400 text-xs uppercase tracking-wide mb-0.5">Amount</p>
                <p className="font-medium text-gray-700">
                  NPR {booking.totalAmount > 0 ? booking.totalAmount.toLocaleString() : '—'}
                </p>
              </div>
            </div>

            {/* Package & Payment badges */}
            <div className="flex flex-wrap gap-2 mt-3">
              {booking.package && (
                <span className="inline-flex items-center gap-1 text-xs bg-orange-50 text-orange-700 border border-orange-200 px-2 py-1 rounded-full">
                  📦 {booking.package.name}
                </span>
              )}
              <span className={`inline-flex items-center gap-1 text-xs px-2 py-1 rounded-full ${PAYMENT_CLASS[booking.paymentStatus] || 'bg-gray-50 text-gray-500'}`}>
                {isPaid ? '✅' : '⏳'} {booking.paymentStatus?.replace('_', ' ')}
              </span>
              {booking.review && (
                <span className="inline-flex items-center gap-1 text-xs bg-yellow-50 text-yellow-700 border border-yellow-200 px-2 py-1 rounded-full">
                  ⭐ Review submitted
                </span>
              )}
            </div>

            {/* Countdown for upcoming */}
            {isUpcoming && <DaysUntil date={eventDate} />}
          </div>

          {/* Action buttons */}
          <div className="flex sm:flex-col gap-2 sm:w-36 flex-shrink-0">
            <button
              onClick={onViewDetails}
              className="flex-1 sm:flex-none text-sm btn-secondary py-1.5 text-center"
            >
              View Details
            </button>
            {!isPaid && isUpcoming && (
              <Link
                to={`/payment/${booking.id}`}
                className="flex-1 sm:flex-none text-sm btn-primary py-1.5 text-center"
              >
                Pay Now
              </Link>
            )}
            {canReview && (
              <button
                onClick={onReview}
                className="flex-1 sm:flex-none text-sm bg-yellow-400 hover:bg-yellow-500 text-white font-semibold py-1.5 px-3 rounded-lg transition-colors"
              >
                ⭐ Review
              </button>
            )}
            {canCancel && (
              <button
                onClick={onCancel}
                className="flex-1 sm:flex-none text-sm bg-white hover:bg-red-50 text-red-500 border border-red-200 font-medium py-1.5 px-3 rounded-lg transition-colors"
              >
                Cancel
              </button>
            )}
          </div>
        </div>
      </div>
    </div>
  );
}

// ── DaysUntil ─────────────────────────────────────────────────
function DaysUntil({ date }: { date: Date }) {
  const now  = new Date();
  const diff = Math.ceil((date.getTime() - now.getTime()) / (1000 * 60 * 60 * 24));
  if (diff < 0)  return null;
  if (diff === 0) return <p className="text-xs text-purple-600 font-semibold mt-2">🎉 Today!</p>;
  if (diff === 1) return <p className="text-xs text-orange-600 font-semibold mt-2">⏰ Tomorrow</p>;
  return <p className="text-xs text-gray-400 mt-2">🗓 In {diff} days</p>;
}

// ── EmptyState ────────────────────────────────────────────────
function EmptyState({ tab }: { tab: Tab }) {
  const msgs: Record<Tab, { icon: string; title: string; sub: string }> = {
    All:       { icon: '📋', title: 'No bookings yet',       sub: 'Start by finding a pandit for your ceremony.' },
    Upcoming:  { icon: '📅', title: 'No upcoming bookings',  sub: 'Book a pandit for your next ceremony.' },
    Completed: { icon: '✅', title: 'No completed bookings', sub: 'Completed ceremonies will appear here.' },
    Cancelled: { icon: '🚫', title: 'No cancelled bookings', sub: 'Cancelled bookings will appear here.' },
  };
  const { icon, title, sub } = msgs[tab];
  return (
    <div className="text-center py-20 text-gray-400">
      <p className="text-5xl mb-4">{icon}</p>
      <p className="text-lg font-medium text-gray-600 mb-1">{title}</p>
      <p className="text-sm mb-6">{sub}</p>
      {(tab === 'All' || tab === 'Upcoming') && (
        <Link to="/pandits" className="btn-primary inline-block">Browse Pandits</Link>
      )}
    </div>
  );
}
